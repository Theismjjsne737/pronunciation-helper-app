# ─────────────────────────────────────────────
# LingoLab – Environment Variable Template
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# .env is git-ignored. This file is safe to commit.
# ─────────────────────────────────────────────

# ── ElevenLabs ───────────────────────────────
# Required for:
#   • TTS  – plays the correct pronunciation of a name
#   • STT  – transcribes the user's recorded audio
#
# Get your key at: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# ElevenLabs voice used for the correct-pronunciation playback.
# "EXAVITQu4vr4xnSDxMaL" = "Sarah" (clear, neutral English).
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ElevenLabs STT model for transcribing recordings.
# "scribe_v1" is the current standard model – leave this as-is.
ELEVENLABS_STT_MODEL=scribe_v1

# ── Anthropic (Claude) ────────────────────────
# Required for generating personalised coaching feedback.
# Get your key at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Server ────────────────────────────────────
# Port the Express API listens on. 3005 avoids clashing with
# other apps in this workspace.
PORT=3005
